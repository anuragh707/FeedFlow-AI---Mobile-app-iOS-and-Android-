# =========================================================================
# FeedFlow Backend Environment Variables Configuration Template
# Rename this file to '.env' and populate key credentials before boot
# =========================================================================

# Encryption secret key used for signing JWT access tokens (generate a long secure hex string)
SECRET_KEY=feedflow_hackathon_super_secret_key_1337_lol

# Database connection URL (defaults to SQLite. For production, specify PostgreSQL/Supabase URL)
# Example: postgresql://postgres:password@localhost:5432/feedflow
DATABASE_URL=sqlite:///./feedflow.db

# Google Gemini API key used for classifying content and generating insights.
# Obtain a key from Google AI Studio: https://aistudio.google.com/
# Leave empty to run the high-fidelity local keyword simulation engine.
GEMINI_API_KEY=
